GPU_ENABLED=true
TORCH_CUDA_MAX_MEMORY_FRAC=0.7
GPU_WARMUP=true
AWS_REGION=ap-south-1
RAW_BUCKET=ahfl-demo-raw-data-bucket #ahfl-ams-raw-data-bucket-333813598364-ap-south-1-an
MASKED_BUCKET=ahfl-uat-demo-masked-data-bucket  #ahfl-uat-ams-masked-data-bucket-333813598364-ap-south-1-an
TABLE_NAME=ahfl_processed_data
MODEL_MAIN=/app/models/main.pt
MODEL_BEST=/app/models/best.pt
MODEL_FRONT_BACK=/app/models/front_back_detect.pt
MODEL_YOLO_N=/app/models/yolov8n.pt
